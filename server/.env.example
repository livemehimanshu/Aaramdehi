# ====================================
# AARAMDEHI SERVER - ENVIRONMENT SETUP
# ====================================

# 🔧 SERVER CONFIGURATION
PORT=8000
FRONTEND_URL=http://localhost:5173

# 🗄️ DATABASE
MONGODB_URI=mongodb://127.0.0.1:27017/aaramdehi

# 🔐 JWT SECRETS (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SECRET_KEY_ACCESS_TOKEN=your_random_32_byte_hex_here
SECRET_KEY_REFRESH_TOKEN=your_random_32_byte_hex_here

# 📧 GMAIL CONFIGURATION (REQUIRED FOR OTP EMAIL)
# Steps to get App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not enabled
# 3. Go to App passwords (bottom of Security page)
# 4. Select "Mail" and "Windows Computer"
# 5. Copy the 16-digit password and paste here (remove spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx  # 16-digit App Password (NOT regular password)

# ☁️ CLOUDINARY (For Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
