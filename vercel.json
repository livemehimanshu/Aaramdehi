{
  "version": 2,
  "name": "aaramdehi",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://aaramdehi.onrender.com/api/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}