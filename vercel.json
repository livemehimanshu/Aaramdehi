{
  "version": 2,
  "functions": {
    "server/index.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/search-api/(.*)",
      "destination": "/my_search_engine/main.py"
    }
  ],
  "cleanUrls": true
}