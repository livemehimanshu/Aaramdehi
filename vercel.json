{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "my_search_engine/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/search-api/(.*)",
      "dest": "/my_search_engine/main.py"
    },
    {
      "src": "^/(?!api|search-api)(?!.*\\.).*$",
      "dest": "/index.html"
    }
  ]
}