{
  "version": 2,
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node@2.0.0"
    },
    "my_search_engine/main.py": {
      "runtime": "@vercel/python@1.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/search-api/(.*)",
      "destination": "/my_search_engine/main.py"
    }
  ],
  "cleanUrls": true
}